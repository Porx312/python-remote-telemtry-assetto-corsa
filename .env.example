# Supabase Postgres (misma lógica que ac-data; sslmode suele ser obligatorio)
DATABASE_URL=postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# Alternativa al nombre anterior
# SUPABASE_DB_URL=

# Tests / DB de prueba
USE_TEST_DB=false
# TEST_DATABASE_URL=

# --- Solo si usas scripts/migrate_mysql_to_supabase.py contra MySQL antiguo ---
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=ac_server_db
# DB_PORT=3306

# Misma API_KEY que el backend Node (ac-data) si envías peticiones autenticadas
API_KEY=cambia_esto_por_un_secreto_largo

# Rutas con server_cfg.ini (separadas por coma). Vacío si no usas esa función.
EVENTS_SERVERS_PATH=
SERVERS_PATH=
TIME_ATTACK_SERVERS_PATH=

BACKEND_URL=http://localhost:3000

# Webhooks hacia Convex u otro backend
EVENT_WEBHOOK_SECRET=
SERVER_EVENT_WEBHOOK_URL=
